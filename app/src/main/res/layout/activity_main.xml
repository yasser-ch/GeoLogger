<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/geo_background"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Geologger"
        android:textColor="@color/geo_orange"
        android:textSize="30sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="8dp"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="@color/geo_card"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📡 Signal GPS"
                android:textColor="@color/geo_orange"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tv_lat_display"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Latitude : —"
                android:textColor="@color/geo_white"
                android:textSize="15sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_lon_display"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Longitude : —"
                android:textColor="@color/geo_white"
                android:textSize="15sp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/waiting_location"
        android:textColor="@color/geo_grey"
        android:textSize="13sp"
        android:gravity="center" />

    <Button
        android:id="@+id/btn_view_map"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="@string/btn_view_map"
        android:backgroundTint="@color/geo_orange"
        android:textColor="@color/geo_white"
        android:textStyle="bold"
        android:padding="14dp" />

</LinearLayout>